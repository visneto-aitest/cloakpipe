[4.84, "o", "Privacy middleware for LLM & RAG pipelines\r\n"]
[4.87, "o", "\r\n"]
[4.9, "o", "\u001b[1;33mUsage:\u001b[0m cloakpipe [OPTIONS] <COMMAND>\r\n"]
[4.93, "o", "\r\n"]
[4.96, "o", "\u001b[1;33mCommands:\u001b[0m\r\n"]
[4.99, "o", "  \u001b[1;32mstart\u001b[0m   Start the CloakPipe proxy server\r\n"]
[5.02, "o", "  \u001b[1;32mtest\u001b[0m    Test detection on sample text\r\n"]
[5.05, "o", "  \u001b[1;32mstats\u001b[0m   Show vault statistics\r\n"]
[5.08, "o", "  \u001b[1;32minit\u001b[0m    Initialize a new cloakpipe.toml config file\r\n"]
[5.11, "o", "  \u001b[1;32mtree\u001b[0m    CloakTree: vectorless document retrieval\r\n"]
[5.14, "o", "  \u001b[1;32mvector\u001b[0m  ADCPE: encrypt/decrypt embedding vectors\r\n"]
[5.17, "o", "  help    Print this message or the help of the given subcommand(s)\r\n"]
[5.2, "o", "\r\n"]
[5.23, "o", "\u001b[1;33mOptions:\u001b[0m\r\n"]
[5.26, "o", "  -c, --config <CONFIG>  Path to configuration file [default: cloakpipe.toml]\r\n"]
[5.29, "o", "  -h, --help             Print help\r\n"]
[5.32, "o", "  -V, --version          Print version\r\n"]
