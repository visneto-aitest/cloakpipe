[36.33, "o", "\u001b[2m# That's it. Point any OpenAI client at CloakPipe:\u001b[0m\r\n"]
[37.13, "o", "\u001b[1;36m  client = OpenAI(base_url=\"http://127.0.0.1:8900/v1\")\r\n"]
[37.25, "o", "\u001b[0m\u001b[2m# Your data is pseudonymized before it leaves your machine.\u001b[0m\r\n"]
[37.37, "o", "\u001b[2m# Responses are rehydrated automatically. Zero code changes.\u001b[0m\r\n"]
